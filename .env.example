# ============================================================
# CoinYan — root environment variable template
# Copy this file to .env and fill in real values before
# running `docker compose up`. Never commit .env to git.
# ============================================================

# ---- auth-service ------------------------------------------
# PostgreSQL connection string (matches auth-db service defaults)
DATABASE_URL=postgresql+asyncpg://coinyan:coinyan@auth-db:5432/auth_db

# Redis connection string (matches redis service defaults)
REDIS_URL=redis://redis:6379/0

# JWT signing secret — MUST be changed for any non-local environment
JWT_SECRET=dev-secret-change-in-production

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Resend transactional email API key
RESEND_API_KEY=re_placeholder

# Sender address for transactional emails
EMAIL_FROM=no-reply@coinyan.dev

# Public URL of the React frontend (used in email links, CORS, etc.)
FRONTEND_BASE_URL=http://localhost:5173

# Sentry DSN for auth-service error tracking (leave blank to disable)
SENTRY_DSN=

# ---- web-bff -----------------------------------------------
# Internal URL of the auth-service (Docker service name resolves inside Compose)
AUTH_SERVICE_URL=http://auth-service:8000

# Sentry DSN for web-bff error tracking (leave blank to disable)
# SENTRY_DSN=

# ---- auth-db (postgres:16-alpine) --------------------------
# These must match the values encoded in DATABASE_URL above
POSTGRES_USER=coinyan
POSTGRES_PASSWORD=coinyan
POSTGRES_DB=auth_db
